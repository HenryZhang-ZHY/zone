---
const today = new Date()
---

<footer>
	<div class="footer-content">
		<div class="footer-links">
			<a href="/rss.xml" class="rss-footer-link">RSS Feed</a>
		</div>
		<p>&copy; {today.getFullYear()} shuzhi.zone All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid #e6e6e6;
		background: #fafafa;
		margin-top: auto;
	}

	.footer-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem;
		text-align: center;
	}

	.footer-links {
		margin-bottom: 1rem;
	}

	.rss-footer-link {
		color: #6b6b6b;
		text-decoration: none;
		font-size: 0.875rem;
		font-weight: 500;
		transition: color 0.2s ease;
	}

	.rss-footer-link:hover {
		color: #ff6600;
	}

	footer p {
		font-size: 0.875rem;
		color: #6b6b6b;
		margin: 0;
		font-weight: 400;
		line-height: 1.5;
	}

	/* Responsive Design */
	@media (max-width: 768px) {
		.footer-content {
			padding: 1.5rem;
		}

		footer p {
			font-size: 0.8125rem;
		}

		.rss-footer-link {
			font-size: 0.8125rem;
		}
	}

	@media (max-width: 480px) {
		.footer-content {
			padding: 1rem;
		}

		footer p {
			font-size: 0.75rem;
		}

		.rss-footer-link {
			font-size: 0.75rem;
		}
	}

	/* Large screens */
	@media (min-width: 1200px) {
		.footer-content {
			padding: 2.5rem;
		}

		footer p {
			font-size: 0.9375rem;
		}

		.rss-footer-link {
			font-size: 0.9375rem;
		}
	}
</style>
