---
const today = new Date()
---

<footer class="footer">
	<ul>
		<li><a href="/rss.xml" class="rss-footer-link">RSS Feed</a></li>
	</ul>
	<p class="copyright">&copy; {today.getFullYear()} shuzhi.zone All rights reserved.</p>
</footer>

<style>
	.footer {
		display: flex;
		flex-direction: column;
		align-items: center;
		border-top: 1px solid var(--z-color-border);
		font-size: var(--z-text-sm);
		padding: var(--z-space-8) 0;
		color: var(--z-color-text-dimmed);
	}
	.footer ul { list-style: none; }
	.copyright {
		color: var(--z-color-text-dimmed);
		font-size: var(--z-text-2xs);
	}
	@media (width >= 48rem) {
		.footer { font-size: var(--z-text-base); }
		.copyright { font-size: var(--z-text-xs); }
	}
	@media (width >= 64rem) {
		.footer { font-size: var(--z-text-lg); }
		.copyright { font-size: var(--z-text-sm); }
	}
</style>
