---
import { type BankHistory } from '../../lib/d-sibs'

interface Props {
  years: string[]
  history: BankHistory['years']
}

const { years, history } = Astro.props
const n = years.length
const points = years
  .map((year, index) => {
    const info = history[year]
    if (!info) return null
    const x = n === 1 ? 40 : (index / (n - 1)) * 68 + 6
    const y = 32 - ((info.group - 0.5) / 4) * 32
    return { x, y, group: info.group }
  })
  .filter((point): point is { x: number; y: number; group: number } => point !== null)
---

<svg class="sparkline" viewBox="0 0 80 32" preserveAspectRatio="none">
  {[1, 2, 3, 4].map((g) => (
    <line x1="0" y1={32 - ((g - 0.5) / 4) * 32} x2="80" y2={32 - ((g - 0.5) / 4) * 32} class="spark-grid" />
  ))}

  {points.length >= 2 && <polyline points={points.map((point) => `${point.x},${point.y}`).join(' ')} class="spark-line" />}

  {points.map((point) => (
    <circle cx={point.x} cy={point.y} r="2.5" class={`spark-dot spark-g${point.group}`} />
  ))}
</svg>

<style>
  .sparkline {
    width: 80px;
    height: 32px;
    vertical-align: middle;
  }

  .spark-grid {
    stroke: var(--z-color-hairline-light);
    stroke-width: 0.5;
    stroke-dasharray: 2 2;
  }

  .spark-line {
    fill: none;
    stroke: var(--z-color-hairline-shade);
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .spark-dot {
    stroke: var(--z-color-background-100);
    stroke-width: 0.75;
  }

  .spark-dot.spark-g1 { fill: var(--z-data-g1); }
  .spark-dot.spark-g2 { fill: var(--z-data-g2); }
  .spark-dot.spark-g3 { fill: var(--z-data-g3); }
  .spark-dot.spark-g4 { fill: var(--z-data-g4); }
</style>
