---
import { type BankHistory, type BankType, typeClass } from '../../lib/d-sibs'

interface Props {
  years: string[]
  history: BankHistory['years']
  latestType: BankType | ''
}

const { years, history, latestType } = Astro.props
const n = years.length
const points = years
  .map((year, index) => {
    const info = history[year]
    if (!info) return null
    const x = n === 1 ? 40 : (index / (n - 1)) * 68 + 6
    const y = 32 - ((info.group - 0.5) / 4) * 32
    return { x, y, type: info.type }
  })
  .filter((point): point is { x: number; y: number; type: BankType } => point !== null)
---

<svg class="sparkline" viewBox="0 0 80 32" preserveAspectRatio="none">
  {[1, 2, 3, 4].map((g) => (
    <line x1="0" y1={32 - ((g - 0.5) / 4) * 32} x2="80" y2={32 - ((g - 0.5) / 4) * 32} class="spark-grid" />
  ))}

  {points.length >= 2 && <polyline points={points.map((point) => `${point.x},${point.y}`).join(' ')} class={`spark-line ${typeClass(latestType, 'spark')}`} />}

  {points.map((point) => (
    <circle cx={point.x} cy={point.y} r="2.5" class={`spark-dot ${typeClass(point.type, 'spark')}`} />
  ))}
</svg>

<style>
  .sparkline {
    width: 80px;
    height: 32px;
    vertical-align: middle;
  }

  .spark-grid {
    stroke: var(--z-color-hairline-light);
    stroke-width: 0.5;
    stroke-dasharray: 2 2;
  }

  .spark-line {
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .spark-line.spark-state { stroke: var(--z-data-state); }
  .spark-line.spark-joint { stroke: var(--z-data-joint); }
  .spark-line.spark-city { stroke: var(--z-data-city); }
  .spark-dot.spark-state { fill: var(--z-data-state); }
  .spark-dot.spark-joint { fill: var(--z-data-joint); }
  .spark-dot.spark-city { fill: var(--z-data-city); }
</style>
