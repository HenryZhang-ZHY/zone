---
import HeaderLink from './HeaderLink.astro'
import { SITE_TITLE } from '../consts'
---

<header>
	<nav>
		<div class="brand">
			<a href="/">{SITE_TITLE}</a>
		</div>
		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/reading">Reading</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0;
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid #e6e6e6;
	}

	nav {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 2rem;
		height: 64px;
	}

	.brand {
		flex-shrink: 0;
	}

	.brand a {
		font-size: 1.25rem;
		font-weight: 700;
		color: #1a1a1a;
		text-decoration: none;
		letter-spacing: -0.01em;
	}

	.brand a:hover {
		color: #0066cc;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	/* Global styles for HeaderLink components */
	.nav-links :global(a) {
		padding: 0.5rem 1rem;
		color: #6b6b6b;
		text-decoration: none;
		font-weight: 500;
		font-size: 0.9375rem;
		border-radius: 6px;
		border: none;
		border-bottom: none;
	}

	.nav-links :global(a:hover) {
		color: #1a1a1a;
	}

	.nav-links :global(a.active) {
		color: #0066cc;
	}

	/* Responsive Design */
	@media (max-width: 768px) {
		nav {
			padding: 1rem 1.5rem;
			height: 56px;
		}

		.brand a {
			font-size: 1.125rem;
		}

		.nav-links :global(a) {
			padding: 0.375rem 0.75rem;
			font-size: 0.875rem;
		}
	}

	@media (max-width: 480px) {
		nav {
			padding: 1rem;
			height: 52px;
		}

		.brand a {
			font-size: 1rem;
		}

		.nav-links {
			gap: 0.25rem;
		}

		.nav-links :global(a) {
			padding: 0.25rem 0.5rem;
			font-size: 0.8125rem;
		}
	}

	/* Large screens */
	@media (min-width: 1200px) {
		nav {
			padding: 1.25rem 2rem;
			height: 72px;
		}

		.brand a {
			font-size: 1.375rem;
		}

		.nav-links :global(a) {
			padding: 0.625rem 1.25rem;
			font-size: 1rem;
		}
	}
</style>
