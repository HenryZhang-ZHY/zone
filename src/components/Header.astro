---
import HeaderLink from './HeaderLink.astro'
import { SITE_TITLE } from '../consts'
---

<header class="header">
	<nav class="nav">
		<div class="brand">
			<a href="/">{SITE_TITLE}</a>
		</div>
		<button class="hamburger" type="button" aria-label="Toggle navigation" aria-expanded="false">
			<span class="hamburger-line"></span>
			<span class="hamburger-line"></span>
			<span class="hamburger-line"></span>
		</button>
		<ul class="nav-links">
			<HeaderLink href="/">Writing</HeaderLink>
			<HeaderLink href="/reading">Reading</HeaderLink>
			<HeaderLink href="/listening">Listening</HeaderLink>
		</ul>
	</nav>
</header>

<script>
	const hamburger = document.querySelector('.hamburger')!
	const navLinks = document.querySelector('.nav-links')!

	hamburger.addEventListener('click', () => {
		const expanded = hamburger.getAttribute('aria-expanded') === 'true'
		hamburger.setAttribute('aria-expanded', String(!expanded))
		navLinks.classList.toggle('open')
	})
</script>

<style>
	.header {
		position: sticky;
		top: 0;
		z-index: var(--z-z-index-navbar);

		background-color: var(--z-color-black);

		border-color: var(--z-color-hairline-light);
		border-bottom: 1px solid var(--z-color-white);
	}

	.nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;

		margin: 0 auto;

		max-width: 96rem;

		padding: 0.75rem 1rem;
	}

	.brand a {
		font-weight: 700;
		letter-spacing: -0.02em;

		font-size: var(--z-text-base);
	}

	.hamburger {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 4px;

		background: none;
		border: none;
		cursor: pointer;
		padding: 0.25rem;
	}

	.hamburger-line {
		display: block;
		width: 1.25rem;
		height: 2px;
		background-color: var(--z-color-white);
		border-radius: 1px;
		transition: transform 0.2s, opacity 0.2s;
	}

	.hamburger[aria-expanded="true"] .hamburger-line:nth-child(1) {
		transform: translateY(6px) rotate(45deg);
	}

	.hamburger[aria-expanded="true"] .hamburger-line:nth-child(2) {
		opacity: 0;
	}

	.hamburger[aria-expanded="true"] .hamburger-line:nth-child(3) {
		transform: translateY(-6px) rotate(-45deg);
	}

	.nav-links {
		display: none;
		flex-direction: column;
		width: 100%;
		gap: 0.5rem;
		padding-top: 0.75rem;
	}

	.nav-links.open {
		display: flex;
	}

	.nav-links a {
		font-weight: 600;
		color: var(--z-color-text-secondary);

		font-size: var(--z-text-sm);
	}

	.nav-links a:hover,
	.nav-links a.active {
		color: var(--z-color-text-accent);
	}

	/* md	48rem (768px) */
	@media (width >= 48rem) {
		.hamburger {
			display: none;
		}

		.nav {
			flex-wrap: nowrap;
			padding: 1rem 1.5rem;
		}

		.brand a {
			font-size: var(--z-text-lg);
		}

		.nav-links {
			display: flex;
			flex-direction: row;
			width: auto;
			align-items: center;
			padding-top: 0;

			gap: 1.5rem;
		}

		.nav-links a {
			font-size: var(--z-text-base);
		}
	}

	/* lg	64rem (1024px) */
	@media (width >= 64rem) {
		.nav {
			padding: 1.25rem 2rem;
		}

		.brand a {
			font-size: var(--z-text-xl);
		}

		.nav-links {
			gap: 2rem;
		}

		.nav-links a {
			font-size: var(--z-text-lg);
		}
	}
</style>
