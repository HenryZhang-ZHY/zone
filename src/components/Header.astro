---
import HeaderLink from './HeaderLink.astro'
import { SITE_TITLE } from '../consts'
---

<header class="header">
	<nav class="nav">
		<div class="brand">
			<a href="/">{SITE_TITLE}</a>
		</div>
		<button class="hamburger" type="button" aria-label="Toggle navigation" aria-expanded="false">
			<span class="hamburger-line"></span>
			<span class="hamburger-line"></span>
			<span class="hamburger-line"></span>
		</button>
		<div class="nav-links">
			<HeaderLink href="/">Writing</HeaderLink>
			<HeaderLink href="/reading">Reading</HeaderLink>
			<HeaderLink href="/listening">Listening</HeaderLink>
		</div>
	</nav>
</header>

<script>
	const hamburger = document.querySelector('.hamburger')!
	const navLinks = document.querySelector('.nav-links')!

	hamburger.addEventListener('click', () => {
		const expanded = hamburger.getAttribute('aria-expanded') === 'true'
		hamburger.setAttribute('aria-expanded', String(!expanded))
		navLinks.classList.toggle('open')
	})

	const mdBreakpoint = window.matchMedia('(min-width: 48rem)')
	mdBreakpoint.addEventListener('change', (e) => {
		if (e.matches) {
			navLinks.classList.remove('open')
			hamburger.setAttribute('aria-expanded', 'false')
		}
	})
</script>

<style>
	@reference "tailwindcss";

	.header {
		position: sticky;
		top: 0;
		z-index: var(--z-z-index-navbar);

		background-color: var(--z-color-black);

		border-color: var(--z-color-hairline-light);
		border-bottom: 1px solid var(--z-color-white);
	}

	.nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;

		margin: 0 auto;

		max-width: 96rem;

		padding: 0.75rem 1rem;

		@media (width >= theme(--breakpoint-md)) {
			flex-wrap: nowrap;
			padding: 1rem 1.5rem;
		}

		@media (width >= theme(--breakpoint-lg)) {
			padding: 1.25rem 2rem;
		}
	}

	.brand a {
		font-weight: 700;
		letter-spacing: -0.02em;

		font-size: var(--z-text-base);

		@media (width >= theme(--breakpoint-md)) {
			font-size: var(--z-text-lg);
		}

		@media (width >= theme(--breakpoint-lg)) {
			font-size: var(--z-text-xl);
		}
	}

	.hamburger {
		--line-height: 2px;
		--line-gap: 4px;
		--line-offset: calc(var(--line-gap) + var(--line-height));

		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: var(--line-gap);

		background: none;
		border: none;
		cursor: pointer;
		padding: 0.25rem;

		@media (width >= theme(--breakpoint-md)) {
			display: none;
		}
	}

	.hamburger-line {
		display: block;
		width: 1.25rem;
		height: var(--line-height);
		background-color: var(--z-color-white);
		transition: transform 0.2s, opacity 0.2s;
	}

	.hamburger[aria-expanded="true"] .hamburger-line:nth-child(1) {
		transform: translateY(var(--line-offset)) rotate(45deg);
	}

	.hamburger[aria-expanded="true"] .hamburger-line:nth-child(2) {
		opacity: 0;
	}

	.hamburger[aria-expanded="true"] .hamburger-line:nth-child(3) {
		transform: translateY(calc(-1 * var(--line-offset))) rotate(-45deg);
	}

	.nav-links {
		display: none;
		flex-direction: column;
		width: 100%;
		gap: 0.5rem;
		padding-top: 0.75rem;

		@media (width >= theme(--breakpoint-md)) {
			display: flex;
			flex-direction: row;
			width: auto;
			align-items: center;
			padding-top: 0;

			gap: 1.5rem;
		}

		@media (width >= theme(--breakpoint-lg)) {
			gap: 2rem;
		}
	}

	.nav-links.open {
		display: flex;
	}

	.nav-links a {
		font-weight: 600;
		color: var(--z-color-text-secondary);

		font-size: var(--z-text-sm);

		@media (width >= theme(--breakpoint-md)) {
			font-size: var(--z-text-base);
		}

		@media (width >= theme(--breakpoint-lg)) {
			font-size: var(--z-text-lg);
		}
	}

	.nav-links a:hover,
	.nav-links a.active {
		color: var(--z-color-text-accent);
	}
</style>
