---
import { Image } from 'astro:assets'
import { getCollection } from 'astro:content'
import AudioPlayer from '../components/audio/AudioPlayer.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { SITE_TITLE } from '../consts'

const episodes = await getCollection('podcast')
---

<BaseLayout title={`Podcast | ${SITE_TITLE}`}>
  <main class="z-main">
    <section class="episodes-container z-stack-list">
      {
        episodes.map((episode, index) => (
          <article class="episode-item z-stack-item--roomy">
            <div class="episode-content">
              <div class="episode-image">
                <Image src={episode.data.ogImage} alt={episode.data.ogTitle} loading={index < 12 ? 'eager' : 'lazy'} width={100} height={100} />
              </div>
              <div class="episode-info">
                <h2 class="episode-title">
                  <a href={episode.data.ogUrl} class="episode-link" target="_blank" rel="noopener noreferrer">
                    {episode.data.ogTitle}
                  </a>
                </h2>

                <div class="episode-controls">
                  <AudioPlayer src={episode.data.ogAudio} />
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </section>
  </main>
</BaseLayout>

<style>
  .episode-content {
    display: flex;
    gap: var(--z-space-6);
    align-items: flex-start;
  }

  .episode-image {
    flex-shrink: 0;
    width: 100px;
    height: 100px;
    overflow: hidden;
  }

  .episode-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .episode-info {
    flex: 1;
    min-width: 0;
  }

  .episode-title {
    font-size: var(--z-text-heading-20);
    font-weight: 600;
    line-height: var(--z-leading-heading-20);
    margin: 0 0 var(--z-space-3) 0;
    color: var(--z-color-heading);
    letter-spacing: var(--z-tracking-heading-20);
  }

  .episode-link {
    color: inherit;
    text-decoration: none;
  }

  .episode-link:hover {
    color: var(--z-color-text-accent);
  }

  .episode-controls {
    display: flex;
    align-items: center;
    gap: var(--z-space-4);
    margin-bottom: var(--z-space-3);
  }

  @media (max-width: 768px) {
    .episode-content {
      gap: var(--z-space-4);
    }

    .episode-image {
      width: 80px;
      height: 80px;
    }

    .episode-title {
      font-size: var(--z-text-heading-16);
      line-height: var(--z-leading-heading-16);
      letter-spacing: var(--z-tracking-heading-16);
      margin-bottom: var(--z-space-2);
    }
  }

  @media (max-width: 480px) {
    .episode-content {
      flex-direction: column;
      gap: var(--z-space-4);
    }

    .episode-image {
      width: 100%;
      height: auto;
      aspect-ratio: 1;
    }

    .episode-info {
      width: 100%;
    }

    .episode-title {
      font-size: var(--z-text-copy-16);
      line-height: var(--z-leading-copy-16);
    }
  }
</style>
