---
import BaseLayout from '../layouts/BaseLayout.astro'
import { SITE_TITLE } from '../consts'
---

<BaseLayout title={`股票卖点计算器 | ${SITE_TITLE}`}>
  <main class="z-main z-main--medium">
    <div class="page-header z-page-header">
      <h1 class="z-page-title">股票卖点计算器</h1>
      <p class="subtitle z-page-subtitle">基于股息率计算合理卖出价格</p>
      <p class="note z-page-note">输入买入成本、持有份额和每股分红，计算卖出部分仓位以将剩余持仓摊薄成本降至目标股息率（4%–100%）所需的卖出价格</p>
    </div>

    <!-- Input Section -->
    <section class="input-section z-section">
      <h2 class="z-section-title">参数输入</h2>
      <div class="input-card">
        <div class="input-grid">
          <div class="input-group">
            <label for="cost">买入成本（元/股）</label>
            <input type="number" id="cost" min="0.01" step="0.01" placeholder="例如 10.00" />
          </div>
          <div class="input-group">
            <label for="shares">股票份额（股）</label>
            <input type="number" id="shares" min="1" step="1" placeholder="例如 1000" />
          </div>
          <div class="input-group">
            <label for="dividend">每股分红（元）</label>
            <input type="number" id="dividend" min="0" step="0.01" placeholder="例如 0.50" />
          </div>
        </div>
        <button id="calc-btn" type="button">计算卖点</button>
      </div>
    </section>

    <!-- Result Section -->
    <section class="table-section z-section" id="result-section" style="display:none;">
      <h2 class="z-section-title">卖出价格参考</h2>
      <div class="summary-cards" id="summary-cards"></div>
      <div class="table-wrapper z-table-wrapper">
        <table class="sell-table z-data-table">
          <thead>
            <tr>
              <th class="col-yield">目标股息率</th>
              <th class="col-lots">卖出股数</th>
              <th class="col-price">卖出价格</th>
              <th class="col-cost">目标摊薄成本</th>
              <th class="col-remain">剩余份额</th>
              <th class="col-profit">盈利比例</th>
            </tr>
          </thead>
          <tbody id="result-body">
          </tbody>
        </table>
      </div>
    </section>

    <!-- Explanation -->
    <section class="explain-section z-section">
      <h2 class="z-section-title">计算说明</h2>
      <div class="explain-card">
        <div class="formula-group">
          <span class="formula-label">目标摊薄成本</span>
          <span class="formula-eq">= 每股分红 ÷ 目标股息率</span>
        </div>
        <div class="formula-group">
          <span class="formula-label">卖出价格 P</span>
          <span class="formula-eq">= (持仓总成本 − 剩余份额 × 目标摊薄成本) ÷ 卖出份额</span>
        </div>
        <div class="formula-group">
          <span class="formula-label">盈利比例</span>
          <span class="formula-eq">= (卖出价格 − 买入成本) ÷ 买入成本 × 100%</span>
        </div>
        <p class="explain-note">策略：以高于买入成本的价格卖出部分仓位，利用卖出收益冲减剩余持仓的账面成本，使剩余股票的每股成本下降至目标股息率对应的价位。表中仅展示卖出价格高于买入成本（可获利）的结果。卖出股数以 100 股为最小单位穷举，目标股息率范围 4%–100%。</p>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  import { calcSellPoints } from '../lib/stock-sell-calc'

  const costInput = document.getElementById('cost') as HTMLInputElement
  const sharesInput = document.getElementById('shares') as HTMLInputElement
  const dividendInput = document.getElementById('dividend') as HTMLInputElement
  const calcBtn = document.getElementById('calc-btn') as HTMLButtonElement
  const resultSection = document.getElementById('result-section') as HTMLElement
  const resultBody = document.getElementById('result-body') as HTMLTableSectionElement
  const summaryCards = document.getElementById('summary-cards') as HTMLElement

  function formatCurrency(n: number): string {
    return n.toLocaleString('zh-CN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
  }

  function formatPercent(n: number): string {
    return n.toLocaleString('zh-CN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '%'
  }

  function yieldClass(pct: number): string {
    if (pct <= 10) return 'yield-low'
    if (pct <= 20) return 'yield-mid'
    if (pct <= 40) return 'yield-high'
    return 'yield-max'
  }

  function profitClass(p: number): string {
    if (p > 0) return 'profit-pos'
    if (p < 0) return 'profit-neg'
    return 'profit-zero'
  }

  function calculate() {
    const cost = parseFloat(costInput.value)
    const shares = parseInt(sharesInput.value)
    const dividend = parseFloat(dividendInput.value)

    if (!cost || cost <= 0 || !shares || shares <= 0 || isNaN(dividend) || dividend < 0) {
      alert('请输入有效的参数：买入成本和份额必须为正数，分红不能为负数。')
      return
    }

    const points = calcSellPoints({ costPerShare: cost, shares, dividendPerShare: dividend })

    if (points.length === 0) {
      alert('没有找到可获利的卖点。请确认：持仓份额 ≥ 200 股，且分红大于 0。')
      return
    }

    const naturalYield = dividend > 0 ? (dividend / cost) * 100 : 0
    const minPrice = Math.min(...points.map((p) => p.sellPrice))
    const maxPrice = Math.max(...points.map((p) => p.sellPrice))

    summaryCards.innerHTML = `
      <div class="summary-card">
        <div class="card-label">买入成本</div>
        <div class="card-value">${formatCurrency(cost)} 元</div>
      </div>
      <div class="summary-card">
        <div class="card-label">自然股息率（基于成本）</div>
        <div class="card-value">${formatPercent(naturalYield)}</div>
      </div>
      <div class="summary-card">
        <div class="card-label">最低卖出价格</div>
        <div class="card-value">${formatCurrency(minPrice)} 元</div>
      </div>
      <div class="summary-card">
        <div class="card-label">最高卖出价格</div>
        <div class="card-value">${formatCurrency(maxPrice)} 元</div>
      </div>
      <div class="summary-card">
        <div class="card-label">可获利结果数</div>
        <div class="card-value">${points.length} 条</div>
      </div>
    `

    // Table rows
    resultBody.innerHTML = points
      .map(
        (p) => `
      <tr>
        <td class="col-yield"><span class="yield-pill ${yieldClass(p.yieldPercent)}">${p.yieldPercent}%</span></td>
        <td class="col-lots">${p.sharesToSell.toLocaleString('zh-CN')} 股</td>
        <td class="col-price">${formatCurrency(p.sellPrice)}</td>
        <td class="col-cost">${formatCurrency(p.dilutedCost)}</td>
        <td class="col-remain">${p.remainingShares.toLocaleString('zh-CN')} 股</td>
        <td class="col-profit"><span class="profit-pos">+${formatPercent(p.profitPercent)}</span></td>
      </tr>
    `,
      )
      .join('')

    resultSection.style.display = ''
    resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' })
  }

  calcBtn.addEventListener('click', calculate)

  // Also allow Enter key to trigger calculation
  ;[costInput, sharesInput, dividendInput].forEach((input) => {
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') calculate()
    })
  })
</script>

<style>
  :root {
    --yield-low: hsl(350, 75%, 45%);
    --yield-low-bg: hsl(350, 70%, 93%);
    --yield-mid: hsl(18, 80%, 50%);
    --yield-mid-bg: hsl(18, 80%, 92%);
    --yield-high: hsl(38, 80%, 45%);
    --yield-high-bg: hsl(38, 75%, 91%);
    --yield-max: hsl(210, 12%, 50%);
    --yield-max-bg: hsl(210, 15%, 92%);

    --profit-pos: hsl(145, 60%, 38%);
    --profit-neg: hsl(0, 65%, 50%);
    --profit-zero: hsl(210, 12%, 50%);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --yield-low: hsl(350, 70%, 62%);
      --yield-low-bg: hsl(350, 30%, 17%);
      --yield-mid: hsl(18, 75%, 60%);
      --yield-mid-bg: hsl(18, 35%, 16%);
      --yield-high: hsl(38, 75%, 58%);
      --yield-high-bg: hsl(38, 35%, 16%);
      --yield-max: hsl(210, 15%, 65%);
      --yield-max-bg: hsl(210, 10%, 18%);

      --profit-pos: hsl(145, 55%, 55%);
      --profit-neg: hsl(0, 65%, 62%);
      --profit-zero: hsl(210, 15%, 65%);
    }
  }

  /* Input Section */
  .input-card {
    background: var(--z-color-black);
    border: 1px solid var(--z-color-white);
    padding: 1.5rem;
  }

  .input-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .input-group label {
    font-size: var(--z-text-sm);
    font-weight: 600;
    color: var(--z-color-text-secondary);
  }

  .input-group input {
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--z-color-white);
    font-size: var(--z-text-base);
    background: var(--z-color-bg);
    color: var(--z-color-text);
    transition: border-color 0.15s;
  }

  .input-group input:focus {
    outline: none;
    border-color: var(--z-color-text-secondary);
  }

  #calc-btn {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    font-size: var(--z-text-sm);
    font-weight: 600;
    border: none;
    cursor: pointer;
    background: var(--z-color-text);
    color: var(--z-color-bg);
    transition: opacity 0.15s;
  }

  #calc-btn:hover {
    opacity: 0.85;
  }

  /* Summary Cards */
  .summary-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .summary-card {
    background: var(--z-color-black);
    border: 1px solid var(--z-color-white);
    padding: 1rem 1.25rem;
  }

  .card-label {
    font-size: var(--z-text-xs);
    color: var(--z-color-text-dimmed);
    margin-bottom: 0.35rem;
  }

  .card-value {
    font-size: var(--z-text-xl);
    font-weight: 700;
  }

  .col-yield {
    min-width: 90px;
    text-align: center;
  }

  th.col-yield {
    text-align: center;
  }

  .col-lots {
    text-align: right;
    min-width: 80px;
    font-variant-numeric: tabular-nums;
  }

  th.col-lots {
    text-align: right;
  }

  .col-price,
  .col-cost {
    text-align: right;
    min-width: 110px;
    font-variant-numeric: tabular-nums;
  }

  th.col-price,
  th.col-cost {
    text-align: right;
  }

  .col-remain {
    text-align: right;
    min-width: 90px;
    font-variant-numeric: tabular-nums;
  }

  th.col-remain {
    text-align: right;
  }

  .col-profit {
    text-align: right;
    min-width: 100px;
    font-variant-numeric: tabular-nums;
  }

  th.col-profit {
    text-align: right;
  }

  .yield-pill {
    display: inline-block;
    font-size: var(--z-text-2xs);
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 1rem;
  }

  .yield-low {
    background: var(--yield-low-bg);
    color: var(--yield-low);
  }

  .yield-mid {
    background: var(--yield-mid-bg);
    color: var(--yield-mid);
  }

  .yield-high {
    background: var(--yield-high-bg);
    color: var(--yield-high);
  }

  .yield-max {
    background: var(--yield-max-bg);
    color: var(--yield-max);
  }

  .profit-pos {
    color: var(--profit-pos);
    font-weight: 600;
  }

  .profit-neg {
    color: var(--profit-neg);
    font-weight: 600;
  }

  .profit-zero {
    color: var(--profit-zero);
    font-weight: 600;
  }

  /* Explanation */
  .explain-card {
    background: var(--z-color-black);
    border: 1px solid var(--z-color-white);
    padding: 1.5rem;
  }

  .formula-group {
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
    margin-bottom: 0.5rem;
    padding: 0.4rem 0;
    font-size: var(--z-text-sm);
  }

  .formula-label {
    font-weight: 600;
    min-width: 5rem;
  }

  .formula-eq {
    color: var(--z-color-text-secondary);
    font-family: var(--z-font-mono, monospace);
  }

  .explain-note {
    margin-top: 1rem;
    font-size: var(--z-text-xs);
    color: var(--z-color-text-dimmed);
    line-height: 1.6;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .summary-cards {
      grid-template-columns: repeat(2, 1fr);
    }

    .input-grid {
      grid-template-columns: 1fr;
    }

    .formula-group {
      flex-direction: column;
      gap: 0.2rem;
    }
  }
</style>
