---
import BaseHead from '../components/BaseHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts'
import { getCollection } from 'astro:content'

const books = await getCollection('book')
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Reading List | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      * {
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, system-ui, sans-serif;
        line-height: 1.6;
        color: #1a1a1a;
        background: #ffffff;
        margin: 0;
        padding: 0;
      }

      main {
        max-width: 680px;
        margin: 0 auto;
        padding: 4rem 2rem 6rem;
        min-height: calc(100vh - 200px);
      }

      .books-container {
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .book-item {
        padding: 2rem 0;
        border-bottom: 1px solid #f0f0f0;
      }

      .book-item:last-child {
        border-bottom: none;
      }

      .book-link {
        display: block;
        text-decoration: none;
        color: inherit;
        transition: transform 0.2s ease;
      }

      .book-link:hover {
        transform: translateY(-2px);
      }

      .book-title {
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1.3;
        margin: 0 0 0.5rem 0;
        color: #1a1a1a;
        letter-spacing: -0.01em;
      }

      .book-link:hover .book-title {
        color: #0066cc;
      }

      .book-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.875rem;
        color: #999;
      }

      .book-source {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        font-weight: 400;
      }

      .external-link-icon {
        width: 12px;
        height: 12px;
        opacity: 0.6;
      }

      /* Book count indicator */
      .books-count {
        font-size: 0.875rem;
        color: #999;
        margin-bottom: 2rem;
        text-align: center;
      }

      /* Empty state */
      .empty-state {
        text-align: center;
        padding: 4rem 0;
        color: #6b6b6b;
      }

      .empty-state h3 {
        font-size: 1.5rem;
        margin: 0 0 1rem 0;
        color: #1a1a1a;
      }

      /* Responsive Design */
      @media (max-width: 768px) {
        main {
          padding: 2rem 1.5rem 4rem;
          max-width: 100%;
        }

        .page-title {
          font-size: 1.75rem;
        }

        .page-description {
          font-size: 1rem;
          margin-bottom: 2rem;
        }

        .book-item {
          padding: 1.5rem 0;
        }

        .book-title {
          font-size: 1.375rem;
          margin-bottom: 0.5rem;
        }

        .book-meta {
          font-size: 0.8125rem;
        }
      }

      @media (max-width: 480px) {
        main {
          padding: 1.5rem 1rem 3rem;
        }

        .page-title {
          font-size: 1.5rem;
        }

        .book-item {
          padding: 1.25rem 0;
        }

        .book-title {
          font-size: 1.25rem;
          line-height: 1.25;
        }
      }

      /* Large screens */
      @media (min-width: 1200px) {
        main {
          max-width: 728px;
          padding: 5rem 2rem 8rem;
        }

        .book-item {
          padding: 2.5rem 0;
        }

        .page-description {
          margin-bottom: 4rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="books-container">
        {
          books.length > 0 ? (
            books.map((book) => (
              <article class="book-item">
                <a href={book.data.url} class="book-link" target="_blank" rel="noopener noreferrer">
                  <h2 class="book-title">{book.data.title}</h2>
                </a>
              </article>
            ))
          ) : (
            <div class="empty-state">
              <h3>No books yet</h3>
              <p>Check back later for new additions to the reading list.</p>
            </div>
          )
        }
      </section>
    </main>
    <Footer />
  </body>
</html>
