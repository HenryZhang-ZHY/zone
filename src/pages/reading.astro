---
import BaseLayout from '../layouts/BaseLayout.astro'
import { SITE_TITLE } from '../consts'
import { getCollection } from 'astro:content'

const readingItems = await getCollection('readingList')

const sortedReadingItems = readingItems.sort(
  (a, b) => b.data.dateRead.getTime() - a.data.dateRead.getTime()
)
---

<BaseLayout title={`Reading | ${SITE_TITLE}`}>
  <main class="z-main reading-page">
    <div class="z-stack-list">
      {sortedReadingItems.length > 0 ? (
        sortedReadingItems.map((item) => (
          <article class="reading-item z-stack-item--roomy">
            <div class="reading-item-main">
              <h2 class="reading-item-title">
                <a href={item.data.ogUrl} target="_blank" rel="noopener noreferrer">
                  {item.data.title}
                </a>
              </h2>
              <div class="reading-item-meta">
                <time class="reading-date" datetime={item.data.dateRead.toISOString().slice(0, 10)}>
                  {new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(item.data.dateRead)}
                </time>
              </div>
            </div>
          </article>
        ))
      ) : (
        <div class="z-empty-state">
          <h3>No articles yet</h3>
          <p>Articles, posts, and papers I've read will appear here.</p>
        </div>
      )}
    </div>
  </main>
</BaseLayout>

<style>
  .reading-page {
    padding-top: var(--z-space-10);
  }

  .reading-section-title {
    font-size: var(--z-text-heading-24);
    font-weight: 600;
    line-height: var(--z-line-height-headings);
    margin-bottom: var(--z-space-8);
    letter-spacing: var(--z-tracking-heading-24);
  }

  .reading-item-main {
    flex: 1;
    min-width: 0;
  }

  .reading-item-title {
    font-size: var(--z-text-heading-20);
    font-weight: 600;
    line-height: var(--z-leading-heading-20);
    letter-spacing: var(--z-tracking-heading-20);
    margin: 0 0 var(--z-space-2) 0;
    color: var(--z-color-heading);
  }

  .reading-item-title a {
    color: inherit;
    text-decoration: none;
  }

  .reading-item-title a:hover {
    color: var(--z-color-text-accent);
  }

  .reading-item-meta {
    display: flex;
    align-items: center;
    gap: var(--z-space-3);
    font-size: var(--z-text-label-13);
    line-height: var(--z-leading-label-13);
  }

  .reading-date {
    color: var(--z-color-text-dimmed);
  }

  @media (max-width: 768px) {
    .reading-section-title {
      font-size: var(--z-text-heading-20);
      line-height: var(--z-leading-heading-20);
      letter-spacing: var(--z-tracking-heading-20);
      margin-bottom: var(--z-space-6);
    }

    .reading-item-title {
      font-size: var(--z-text-heading-16);
      line-height: var(--z-leading-heading-16);
      letter-spacing: var(--z-tracking-heading-16);
    }
  }

  @media (max-width: 480px) {
    .reading-item-title {
      font-size: var(--z-text-copy-16);
      line-height: var(--z-leading-copy-16);
      letter-spacing: 0;
    }

    .reading-item-meta {
      gap: var(--z-space-2);
    }
  }
</style>
