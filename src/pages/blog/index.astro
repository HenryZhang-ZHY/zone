---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				max-width: 800px;
				margin: 0 auto;
				padding: 2rem 1rem;
			}
			.blog-header {
				text-align: center;
				margin-bottom: 3rem;
			}
			.blog-header h1 {
				font-size: 2.5rem;
				font-weight: 700;
				color: rgb(var(--black));
				margin-bottom: 0.5rem;
			}
			.blog-header p {
				color: rgb(var(--gray));
				font-size: 1.1rem;
			}
			ul {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				background: rgba(var(--accent-light), 0.02);
				border: 1px solid rgba(var(--accent), 0.1);
				border-radius: 16px;
				overflow: hidden;
				transition: all 0.3s ease;
				box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
			}
			ul li:hover {
				transform: translateY(-2px);
				box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
				border-color: rgba(var(--accent), 0.2);
			}
			ul li a {
				display: block;
				padding: 2rem;
				text-decoration: none;
				color: inherit;
			}
			.post-content {
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				font-size: 1.5rem;
				font-weight: 600;
				line-height: 1.3;
				transition: color 0.2s ease;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				font-weight: 500;
				text-transform: uppercase;
				letter-spacing: 0.5px;
			}
			.excerpt {
				margin: 0;
				color: rgb(var(--gray-dark));
				font-size: 1rem;
				line-height: 1.6;
				opacity: 0.8;
			}
			ul li a:hover .title {
				color: rgb(var(--accent));
			}
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			.post-meta {
				display: flex;
				align-items: center;
				gap: 1rem;
				margin-top: 0.5rem;
			}
			.read-more {
				color: rgb(var(--accent));
				font-size: 0.9rem;
				font-weight: 500;
				opacity: 0;
				transition: opacity 0.2s ease;
			}
			ul li:hover .read-more {
				opacity: 1;
			}
			@media (max-width: 768px) {
				main {
					padding: 1rem;
				}
				.blog-header h1 {
					font-size: 2rem;
				}
				ul li a {
					padding: 1.5rem;
				}
				.title {
					font-size: 1.3rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<div class="post-content">
										<h4 class="title">{post.data.title}</h4>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										{post.data.description && <p class="excerpt">{post.data.description}</p>}
										<div class="post-meta">
											<span class="read-more">Read more →</span>
										</div>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
