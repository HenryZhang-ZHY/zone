---
import BaseHead from '../components/BaseHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts'
import { getCollection } from 'astro:content'

const episodes = await getCollection('podcast')
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Podcast | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      * {
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, system-ui, sans-serif;
        line-height: 1.6;
        color: #1a1a1a;
        background: #ffffff;
        margin: 0;
        padding: 0;
      }

      main {
        max-width: 680px;
        margin: 0 auto;
        padding: 4rem 2rem 6rem;
        min-height: calc(100vh - 200px);
      }

      .episodes-container {
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .episode-item {
        padding: 2rem 0;
        border-bottom: 1px solid #f0f0f0;
      }

      .episode-item:last-child {
        border-bottom: none;
      }

      .episode-content {
        display: flex;
        gap: 1.5rem;
        align-items: flex-start;
      }

      .episode-image {
        flex-shrink: 0;
        width: 120px;
        height: 120px;
        border-radius: 8px;
        overflow: hidden;
        background: #f5f5f5;
      }

      .episode-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .episode-info {
        flex: 1;
        min-width: 0;
      }

      .episode-title {
        font-size: 1.25rem;
        font-weight: 700;
        line-height: 1.3;
        margin: 0 0 1rem 0;
        color: #1a1a1a;
        letter-spacing: -0.01em;
      }

      .episode-link {
        color: inherit;
        text-decoration: none;
      }

      .episode-link:hover .episode-title {
        color: #0066cc;
      }

      .episode-controls {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
      }

      .play-button {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border: none;
        border-radius: 50%;
        background: #0066cc;
        color: white;
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 0;
      }

      .play-button:hover {
        background: #0052a3;
        transform: scale(1.05);
      }

      .play-button:disabled {
        background: #ccc;
        cursor: not-allowed;
        transform: none;
      }

      .play-button svg {
        width: 16px;
        height: 16px;
        fill: currentColor;
      }

      .audio-player {
        flex: 1;
        height: 40px;
        border-radius: 20px;
        background: #f5f5f5;
        padding: 0 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .audio-player audio {
        flex: 1;
        height: 30px;
      }

      .episode-meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.875rem;
        color: #999;
      }

      .external-link {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        font-weight: 400;
        text-decoration: none;
        color: #0066cc;
      }

      .external-link:hover {
        text-decoration: underline;
      }

      .external-link-icon {
        width: 12px;
        height: 12px;
        opacity: 0.6;
      }

      /* Loading state */
      .loading {
        opacity: 0.6;
      }

      /* Empty state */
      .empty-state {
        text-align: center;
        padding: 4rem 0;
        color: #6b6b6b;
      }

      .empty-state h3 {
        font-size: 1.5rem;
        margin: 0 0 1rem 0;
        color: #1a1a1a;
      }

      /* Responsive Design */
      @media (max-width: 768px) {
        main {
          padding: 2rem 1.5rem 4rem;
          max-width: 100%;
        }

        .episode-content {
          flex-direction: column;
          gap: 1rem;
        }

        .episode-image {
          width: 100%;
          height: 200px;
          align-self: center;
          max-width: 300px;
        }

        .episode-item {
          padding: 1.5rem 0;
        }

        .episode-title {
          font-size: 1.125rem;
          margin-bottom: 0.75rem;
        }

        .episode-controls {
          gap: 0.75rem;
        }

        .play-button {
          width: 36px;
          height: 36px;
        }

        .play-button svg {
          width: 14px;
          height: 14px;
        }
      }

      @media (max-width: 480px) {
        main {
          padding: 1.5rem 1rem 3rem;
        }

        .episode-item {
          padding: 1.25rem 0;
        }

        .episode-title {
          font-size: 1rem;
          line-height: 1.25;
        }

        .episode-controls {
          flex-direction: column;
          align-items: stretch;
          gap: 0.75rem;
        }

        .audio-player {
          height: 36px;
          padding: 0 0.75rem;
        }
      }

      /* Large screens */
      @media (min-width: 1200px) {
        main {
          max-width: 728px;
          padding: 5rem 2rem 8rem;
        }

        .episode-item {
          padding: 2.5rem 0;
        }

        .episode-image {
          width: 140px;
          height: 140px;
        }

        .episode-title {
          font-size: 1.375rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section class="episodes-container">
        {
          episodes.length > 0 ? (
            episodes.map((episode) => (
              <article class="episode-item">
                <div class="episode-content">
                  <div class="episode-image">
                    <img src={episode.data.ogImage} alt={episode.data.ogTitle} loading="lazy" />
                  </div>
                  <div class="episode-info">
                    <h2 class="episode-title">
                      <a href={episode.data.ogUrl} class="episode-link" target="_blank" rel="noopener noreferrer">
                        {episode.data.ogTitle}
                      </a>
                    </h2>

                    <div class="episode-controls">
                      <div class="audio-player">
                        <audio controls preload="none">
                          <source src={episode.data.ogAudio} type="audio/mpeg" />
                          Your browser does not support the audio element.
                        </audio>
                      </div>
                    </div>

                    <div class="episode-meta">
                      <a href={episode.data.ogUrl} class="external-link" target="_blank" rel="noopener noreferrer">
                        View Original
                        <svg class="external-link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                          <polyline points="15,3 21,3 21,9" />
                          <line x1="10" y1="14" x2="21" y2="3" />
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
              </article>
            ))
          ) : (
            <div class="empty-state">
              <h3>No episodes yet</h3>
              <p>Check back later for new podcast episodes.</p>
            </div>
          )
        }
      </section>
    </main>
    <Footer />

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const playButtons = document.querySelectorAll('.play-button')
        const audioElements = document.querySelectorAll('audio')
        let currentAudio = null
        let currentButton = null

        playButtons.forEach((button, index) => {
          const audio = audioElements[index]
          const playIcon = button.querySelector('.play-icon')
          const pauseIcon = button.querySelector('.pause-icon')

          button.addEventListener('click', () => {
            // Pause other audio if playing
            if (currentAudio && currentAudio !== audio) {
              currentAudio.pause()
              resetButton(currentButton)
            }

            if (audio.paused) {
              // Play audio
              button.disabled = true
              audio
                .play()
                .then(() => {
                  playIcon.style.display = 'none'
                  pauseIcon.style.display = 'block'
                  currentAudio = audio
                  currentButton = button
                  button.disabled = false
                })
                .catch((error) => {
                  console.error('Error playing audio:', error)
                  button.disabled = false
                })
            } else {
              // Pause audio
              audio.pause()
              resetButton(button)
            }
          })

          // Listen for audio events
          audio.addEventListener('ended', () => {
            resetButton(button)
            currentAudio = null
            currentButton = null
          })

          audio.addEventListener('pause', () => {
            if (currentButton === button) {
              resetButton(button)
            }
          })

          audio.addEventListener('play', () => {
            if (currentAudio && currentAudio !== audio) {
              resetButton(currentButton)
            }
            playIcon.style.display = 'none'
            pauseIcon.style.display = 'block'
            currentAudio = audio
            currentButton = button
          })
        })

        function resetButton(button) {
          const playIcon = button.querySelector('.play-icon')
          const pauseIcon = button.querySelector('.pause-icon')
          playIcon.style.display = 'block'
          pauseIcon.style.display = 'none'
        }
      })
    </script>
  </body>
</html>
