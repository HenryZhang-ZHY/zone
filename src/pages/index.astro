---
import BaseLayout from '../layouts/BaseLayout.astro'

import { getCollection } from 'astro:content'
import FormattedDate from '../components/FormattedDate.astro'

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
---

<BaseLayout>
	<main class="z-main">
		<section class="posts-container z-stack-list">
			{
				posts.length > 0 ? (
					posts.map((post) => (
						<article class="post-item z-stack-item">
							<a href={post.data.redirect || `/blog/${post.id}/`} class="post-link z-link-reset">
								<h2 class="post-title">{post.data.title}</h2>
								{post.data.description && <p class="post-excerpt">{post.data.description}</p>}
								<div class="post-meta">
									<time class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</time>
								</div>
							</a>
						</article>
					))
				) : (
					<div class="empty-state z-empty-state">
						<h3>No posts yet</h3>
						<p>Check back later for new content.</p>
					</div>
				)
			}
		</section>
	</main>
</BaseLayout>

<style>
	* {
		box-sizing: border-box;
	}

	.post-title {
		font-size: var(--z-text-heading-20);
		font-weight: 600;
		line-height: var(--z-leading-heading-20);
		margin: 0 0 var(--z-space-3) 0;
		letter-spacing: var(--z-tracking-heading-20);
		color: var(--z-color-heading);
	}

	.post-link:hover .post-title {
		color: var(--z-color-text-accent);
	}

	.post-excerpt {
		font-size: var(--z-text-copy-16);
		color: var(--z-color-text-secondary);
		line-height: var(--z-leading-copy-16);
		margin: 0 0 var(--z-space-4) 0;
		font-weight: 400;
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: var(--z-space-2);
		font-size: var(--z-text-label-13);
		line-height: var(--z-leading-label-13);
		color: var(--z-color-text-dimmed);
	}

	.post-date {
		font-weight: 400;
		text-transform: none;
		letter-spacing: 0;
	}

	.divider {
		margin: 0 var(--z-space-2);
		color: var(--z-color-hairline-light);
	}

	.read-time {
		color: var(--z-color-text-dimmed);
	}

	@media (max-width: 768px) {
		.post-title {
			font-size: var(--z-text-heading-16);
			line-height: var(--z-leading-heading-16);
			letter-spacing: var(--z-tracking-heading-16);
			margin-bottom: var(--z-space-2);
		}

		.post-excerpt {
			font-size: var(--z-text-copy-14);
			line-height: var(--z-leading-copy-14);
			margin-bottom: var(--z-space-3);
		}

		.post-meta {
			font-size: var(--z-text-label-12);
			line-height: var(--z-leading-label-12);
		}
	}

	@media (max-width: 480px) {
		.post-title {
			font-size: var(--z-text-heading-16);
			line-height: var(--z-leading-heading-16);
		}

		.post-excerpt {
			font-size: var(--z-text-copy-14);
			line-height: var(--z-leading-copy-14);
		}
	}

	@media (min-width: 1200px) {
		.post-item {
			padding-bottom: var(--z-space-10);
		}

		.post-item + .post-item {
			padding-top: var(--z-space-10);
		}
	}
</style>
