---
import type { CollectionEntry } from 'astro:content'
import type { MarkdownHeading } from 'astro'
import FormattedDate from '../components/FormattedDate.astro'
import BaseLayout from '../layouts/BaseLayout.astro'

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: MarkdownHeading[]
}

const { title, description, pubDate, updatedDate, headings = [] } = Astro.props

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3)
---

<BaseLayout title={title} description={description} pageLayout="article">
	<div class="blog-layout z-main">
		<main>
			<article>
				<header class="article-header">
					<h1 class="article-title">{title}</h1>
					<div class="article-meta">
						<time class="publish-date">
							<FormattedDate date={pubDate} />
						</time>
						{
							updatedDate && (
								<div class="updated-date">
									Updated on <FormattedDate date={updatedDate} />
								</div>
							)
						}
					</div>
				</header>

				{tocHeadings.length > 0 && (
					<nav class="toc toc-mobile" aria-label="Table of contents">
						<details>
							<summary class="toc-title">Table of Contents</summary>
							<ul class="toc-list">
								{tocHeadings.map((heading) => (
									<li class:list={['toc-item', `toc-depth-${heading.depth}`]}>
										<a href={`#${heading.slug}`} class="toc-link">{heading.text}</a>
									</li>
								))}
							</ul>
						</details>
					</nav>
				)}

				<div class="z-markdown-content">
					<slot />
				</div>
			</article>
		</main>

		{tocHeadings.length > 0 && (
			<aside class="toc toc-desktop" aria-label="Table of contents">
				<div class="toc-sticky">
					<p class="toc-title">Table of Contents</p>
					<ul class="toc-list">
						{tocHeadings.map((heading) => (
							<li class:list={['toc-item', `toc-depth-${heading.depth}`]}>
								<a href={`#${heading.slug}`} class="toc-link">{heading.text}</a>
							</li>
						))}
					</ul>
				</div>
			</aside>
		)}
	</div>
</BaseLayout>

<script>
	function initToc() {
		const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link')
		if (tocLinks.length === 0) return

		const headingIds = Array.from(tocLinks).map((link) =>
			link.getAttribute('href')!.slice(1)
		)
		const headingElements = headingIds
			.map((id) => document.getElementById(id))
			.filter((el): el is HTMLElement => el !== null)

		if (headingElements.length === 0) return

		function setActive(id: string) {
			tocLinks.forEach((link) => {
				const linkId = link.getAttribute('href')!.slice(1)
				link.classList.toggle('active', linkId === id)
			})
		}

		const observer = new IntersectionObserver(
			(entries) => {
				// Find the topmost visible heading
				const visible = entries
					.filter((e) => e.isIntersecting)
					.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)

				if (visible.length > 0) {
					setActive(visible[0].target.id)
					return
				}

				// If no heading is visible, find the last heading above the viewport
				const scrollY = window.scrollY
				let currentId = headingIds[0]
				for (const el of headingElements) {
					if (el.offsetTop <= scrollY + 100) {
						currentId = el.id
					} else {
						break
					}
				}
				setActive(currentId)
			},
			{ rootMargin: '-80px 0px -70% 0px', threshold: 0 }
		)

		headingElements.forEach((el) => observer.observe(el))

		// Set initial active state
		const scrollY = window.scrollY
		let currentId = headingIds[0]
		for (const el of headingElements) {
			if (el.offsetTop <= scrollY + 100) {
				currentId = el.id
			} else {
				break
			}
		}
		setActive(currentId)
	}

	// Run on initial load and after Astro page transitions
	initToc()
	document.addEventListener('astro:after-swap', initToc)
</script>

<style>
	main {
		width: 100%;
	}

	article {
		width: 100%;
	}

	.article-header {
		margin-bottom: var(--z-space-16);
		padding-bottom: var(--z-space-8);
		border-bottom: 1px solid var(--z-color-hairline-light);
		text-align: left;
	}

	.article-title {
		font-size: var(--z-text-heading-48);
		font-weight: 600;
		line-height: var(--z-leading-heading-48);
		margin: 0 0 var(--z-space-6) 0;
		letter-spacing: var(--z-tracking-heading-48);
		color: var(--z-color-heading);
	}

	.article-meta {
		display: flex;
		align-items: center;
		gap: var(--z-space-4);
		font-size: var(--z-text-label-13);
		line-height: var(--z-leading-label-13);
		margin-bottom: 0;
	}

	.publish-date {
		font-weight: 400;
		color: var(--z-color-text-secondary);
	}

	.updated-date {
		font-style: italic;
		color: var(--z-color-text-dimmed);
		font-size: var(--z-text-label-12);
		line-height: var(--z-leading-label-12);
	}

	.toc-title {
		font-size: var(--z-text-label-14);
		line-height: var(--z-leading-label-14);
		font-weight: 600;
		color: var(--z-color-primary);
		margin: 0 0 var(--z-space-3) 0;
	}

	.toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.toc-item {
		line-height: 1.5;
	}

	.toc-depth-3 {
		padding-inline-start: var(--z-space-4);
	}

	.toc-link {
		display: block;
		padding: var(--z-space-1) var(--z-space-2);
		font-size: var(--z-text-label-12);
		line-height: var(--z-leading-label-12);
		color: var(--z-color-text-dimmed);
		border-inline-start: 2px solid transparent;
		transition: color 150ms ease, border-color 150ms ease;
		text-decoration: none;
	}

	.toc-link:hover {
		color: var(--z-color-text);
	}

	.toc-link:global(.active) {
		color: var(--z-color-text-accent);
		border-inline-start-color: var(--z-color-text-accent);
	}

	.toc-mobile {
		margin-bottom: var(--z-space-8);
		border: 1px solid var(--z-color-hairline-light);
		border-radius: var(--z-radius-subtle);
		padding: var(--z-space-3) var(--z-space-4);
	}

	.toc-mobile .toc-title {
		cursor: pointer;
		margin: 0;
		user-select: none;
		font-size: var(--z-text-label-14);
		line-height: var(--z-leading-label-14);
	}

	.toc-mobile .toc-list {
		margin-top: var(--z-space-3);
	}

	.toc-desktop {
		display: none;
	}

	@media (max-width: 768px) {
		.article-header {
			margin-bottom: var(--z-space-8);
			padding-bottom: var(--z-space-6);
		}

		.article-title {
			font-size: var(--z-text-heading-32);
			line-height: var(--z-leading-heading-32);
			letter-spacing: var(--z-tracking-heading-32);
			margin-bottom: var(--z-space-4);
		}

		.article-meta {
			flex-direction: column;
			align-items: flex-start;
			gap: var(--z-space-2);
		}
	}

	@media (max-width: 480px) {
		.article-title {
			font-size: var(--z-text-heading-24);
			line-height: var(--z-leading-heading-24);
			letter-spacing: var(--z-tracking-heading-24);
		}
	}

	/* Large screens: balance the right TOC with a matching left spacer column. */
	@media (min-width: 1280px) {
		.blog-layout {
			display: grid;
			grid-template-columns: var(--z-article-side-column-width) minmax(0, min(100%, var(--z-content-width))) var(--z-article-side-column-width);
			column-gap: var(--z-article-grid-column-gap);
			align-items: start;
		}

		.blog-layout > main {
			grid-column: 2;
			min-width: 0;
		}

		.article-header {
			margin-bottom: var(--z-space-16);
		}

		.toc-mobile {
			display: none;
		}

		.toc-desktop {
			align-self: stretch;
			display: block;
			grid-column: 3;
			grid-row: 1;
			min-width: 0;
		}

		.toc-sticky {
			position: sticky;
			top: var(--z-space-8);
			max-height: calc(100vh - var(--z-space-16));
			overflow-y: auto;
			padding-inline-end: var(--z-space-2);
			scrollbar-color: var(--z-color-border-hover) transparent;
			scrollbar-width: thin;
		}

		.toc-sticky::-webkit-scrollbar {
			width: 6px;
		}

		.toc-sticky::-webkit-scrollbar-track {
			background: transparent;
		}

		.toc-sticky::-webkit-scrollbar-thumb {
			background-color: var(--z-color-border-hover);
			border-radius: var(--z-radius-subtle);
		}

		.toc-sticky::-webkit-scrollbar-thumb:hover {
			background-color: var(--z-color-border-active);
		}
	}
</style>
